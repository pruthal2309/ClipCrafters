# ============================================
# RAG Video Script Generator - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual API keys

# ── Groq LLM API ──────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Stability.ai API ──────────────────────────────────
# Get your API key from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_api_key_here

# ── Google Gemini API ─────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Murf AI Text-to-Speech API ────────────────────────
# Get your API key from: https://murf.ai/
MURF_API_KEY=your_murf_api_key_here

# ── Embedding Model ───────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Chunking Configuration ────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval Configuration ───────────────────────────
TOP_K=10
MMR_DIVERSITY_LAMBDA=0.5

# ── Upload Limits ─────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Storage Paths ─────────────────────────────────────
UPLOAD_DIR=app/storage/uploads
INDEX_DIR=app/storage/indices
PARSED_DIR=app/storage/parsed
SCRIPTS_DIR=app/storage/scripts
PROJECTS_DIR=app/storage/projects

# ── Server Configuration ──────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
