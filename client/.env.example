# ── Backend API URL ───────────────────────────────
# Development: Point to local backend server
VITE_API_URL=http://localhost:5001/api

# FastAPI Backend URL (for RAG Video Generator)
VITE_FASTAPI_URL=http://localhost:8000

# Production: Replace with your deployed backend URL
# VITE_API_URL=https://api.clipcrafters.com/api
# VITE_FASTAPI_URL=https://fastapi.clipcrafters.com

# ── Application Settings ──────────────────────────
# Enable debug mode for development
VITE_DEBUG=true

# App name (optional)
VITE_APP_NAME=ClipCrafters

# ── Feature Flags (optional) ──────────────────────
# Enable/disable features during development
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DARK_MODE=true
